{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Tauri App",
  "version": "0.0.0",
  "identifier": "com.mew.tauri-app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Tauri App",
        "width": 800,
        "height": 700,
        "resizable": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "your-public-key-here",
      "endpoints": [
        "https://github.com/mewisme/repo/releases/latest/download/latest.json"
      ]
    }
  }
}